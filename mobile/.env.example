# ==============================================================================
# ÁGORA - Variáveis de Ambiente do App (mobile/)
# ==============================================================================

# Supabase (Banco de Dados / Auth) — OBRIGATÓRIO
EXPO_PUBLIC_SUPABASE_URL=https://<SUA-URL-AQUI>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUz...

# Google Maps (Opcional — fallback para OSM/Stadia Maps se não configurado)
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...

# URL pública do app (usado nas Edge Functions para gerar links de convite/rastreamento)
EXPO_PUBLIC_APP_URL=https://agora-app-swart.vercel.app

# ==============================================================================
# CHAVES DE API DE TERCEIROS — NÃO use EXPO_PUBLIC_ para essas!
# Variáveis EXPO_PUBLIC_* são embutidas no bundle do app e podem ser extraídas.
#
# Configure como secrets das Edge Functions no servidor Supabase:
#
#   npx supabase secrets set GROQ_API_KEY=gsk_...
#
# Documentação: https://supabase.com/docs/guides/functions/secrets
# ==============================================================================
